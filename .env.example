# CTF Professor - Environment Variables Template
# Copy this file to .env and fill in your credentials.
# NEVER commit your actual .env file to version control.

# --- CTFd Configuration ---
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=your_ctfd_token_here

# --- HackTheBox Configuration ---
HTB_TOKEN=your_htb_app_token_here

# --- TryHackMe Configuration ---
# Copy the 'connect.sid' cookie value from your browser
THM_SESSION_SID=your_thm_session_sid_here

# --- Sandbox Configuration (Optional) ---
# Default container name is 'ctf_sandbox'
# SANDBOX_CONTAINER_NAME=my_custom_sandbox
